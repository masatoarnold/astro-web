---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import CollectionCard from "@components/CollectionCard.astro";
import RectButton from "@components/RectButton.astro";
import ChevronLeft from "@lucide/astro/icons/chevron-left";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  // Get unique tags
  const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))];

  // Create paths for each tag
  return tags.map((tag) => ({
    params: { id: tag },
    props: {
      posts: posts.filter((post) => post.data.tags?.includes(tag)),
    },
  }));
}

const { id } = Astro.params;
const { posts } = Astro.props;

// Sort posts by date, most recent first
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout title={`Tag: ${id}`} description={`Posts with the tag: ${id}`}>
  <Container>
    <div class="space-y-10" data-pagefind-ignore>
      <RectButton
        data-pagefind-ignore
        href="/tags"
        class="not-prose w-fit gap-1"
      >
        <ChevronLeft class="size-5" />
        <div class="text-sm">All tags</div>
      </RectButton>
      <h1 class="font-semibold text-black dark:text-white">
        Posts tagged with "{id}"
      </h1>
      <ul class="flex flex-col gap-4">
        {sortedPosts.map((post) => <CollectionCard entry={post} />)}
      </ul>
    </div>
  </Container>
</Layout>
