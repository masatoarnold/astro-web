---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE } from "@consts";
import RectButton from "@components/RectButton.astro";
import ChevronLeft from "@lucide/astro/icons/chevron-left";
---

<Layout title="404" description={SITE.DESCRIPTION}>
  <Container>
    <div class="mt-16 grid place-items-center gap-3" data-pagefind-ignore>
      <h4 class="text-2xl font-semibold text-black dark:text-white">
        404: Page not found
      </h4>
      <RectButton data-pagefind-ignore href="/" class="not-prose w-fit gap-1">
        <ChevronLeft class="size-5" />
        <div class="text-sm">Go to home page</div>
      </RectButton>
    </div>
  </Container>
</Layout>
